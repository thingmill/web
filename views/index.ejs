<% include header %>
<div id="accueil" class="layout-main">
   <div class="section home">
      <h1 class="home">Imaginer, innover et réaliser</h1>
      <p class="home-desc">Thingmill, pour un vent de fraicheur</p>
      <div class="home-actions-button">
         <p class="contact-submit">
            <a class="waves-effect waves-light btn-large btn" href="#about">En savoir plus</a>
         </p>
         <p class="contact-submit">
            <a class="waves-effect waves-light btn-large btn" href="#app">
            Nous contacter
