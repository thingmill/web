<div class="col-md-2" style="margin: 60px 0px;">
   <a href="https://web-advance.fr/projets" class="button-primary">Découvrir plus</a>
</div>
<div class="container">
   <div class="section" id="team">
      <h1 class="title new-section">Notre équipe</h1>
      <div class="row center">
         <div class="col s12 m4">
            <img alt="" class="avatar" src="img/valentin.png" />
            <h1 class="name">Valentin Derouet</h1>
            <p class="desc center">16 ans, concepteur électronique et dev web</p>
            <a class="btn-floating btn waves-effect waves-light media-icon" style="background: #171516" target="_blank"
               href="https://github.com/StoneSet"><i class="fab fa-github"></i></a>
            <a class="btn-floating btn waves-effect waves-light media-icon" style="background: #00ACED" target="_blank"
               href="https://twitter.com/_StoneSet"><i class="fab fa-twitter"></i></a>
            <a class="btn-floating btn waves-effect waves-light media-icon" style="background: #00FF00" target="_blank"
               href="https://stoneset.me"><i class="fas fa-link "></i></a>
         </div>
         <div class="col s12 m4">
            <img alt="" class="avatar" src="img/etienne.jpg" />
            <h1 class="name">Etienne Chevrollier</h1>
            <p class="desc center">16 ans, infographiste et idéaliste</p>
            <a class="btn-floating btn waves-effect waves-light media-icon" style="background: #00ACED" target="_blank"
               href="https://twitter.com/EtienneCvr"><i class="fab fa-twitter"></i></a>
            <a class="btn-floating btn waves-effect waves-light media-icon" style="background: #da3e56" target="_blank"
               href="https://wabfall.me"><i class="fas fa-link "></i></a>
         </div>
         <div class="col s12 m4">
            <img alt="" class="avatar" src="img/matthieu.jpg" />
            <h1 class="name">Matthieu Bessat</h1>
